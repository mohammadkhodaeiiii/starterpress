{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "تاریک",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "background", "color": "#0f172a", "name": "Background" },
				{ "slug": "foreground", "color": "#f1f5f9", "name": "Foreground" },
				{ "slug": "primary", "color": "#60a5fa", "name": "Primary" },
				{ "slug": "primary-foreground", "color": "#0f172a", "name": "Primary foreground" },
				{ "slug": "secondary", "color": "#38bdf8", "name": "Secondary" },
				{ "slug": "accent", "color": "#fbbf24", "name": "Accent" },
				{ "slug": "muted", "color": "#1e293b", "name": "Muted" },
				{ "slug": "muted-foreground", "color": "#94a3b8", "name": "Muted foreground" },
				{ "slug": "border", "color": "#334155", "name": "Border" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--primary-foreground)"
				}
			}
		}
	}
}
