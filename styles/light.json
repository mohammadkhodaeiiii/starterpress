{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "روشن",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "background", "color": "#fafafa", "name": "Background" },
				{ "slug": "foreground", "color": "#1f2937", "name": "Foreground" },
				{ "slug": "primary", "color": "#2563eb", "name": "Primary" },
				{ "slug": "primary-foreground", "color": "#ffffff", "name": "Primary foreground" },
				{ "slug": "secondary", "color": "#38bdf8", "name": "Secondary" },
				{ "slug": "accent", "color": "#fbbf24", "name": "Accent" },
				{ "slug": "muted", "color": "#f3f4f6", "name": "Muted" },
				{ "slug": "muted-foreground", "color": "#9ca3af", "name": "Muted foreground" },
				{ "slug": "border", "color": "#e5e7eb", "name": "Border" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		}
	}
}
